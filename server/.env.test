# OmniWriter Server Configuration - TEST PORT

# Server
PORT=54321
# HOST=127.0.0.1
NODE_ENV=development

# Database
DATABASE_PATH=./data/omniwriter.db

# JWT
JWT_SECRET=omniwriter-dev-jwt-secret-2026
JWT_EXPIRES_IN=24h
JWT_REMEMBER_ME_EXPIRES_IN=30d

# Session
SESSION_SECRET=omniwriter-dev-session-secret-2026

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:54321/api/auth/google/callback

# AI Providers
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000
